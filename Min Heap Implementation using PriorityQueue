Min Heap Implementation using PriorityQueue

import java.util.*;

public class Main {
    public static void main(String[] args) {
      PriorityQueue<Integer> pq=new PriorityQueue<>();
      pq.add(10);
      pq.add(30);
      pq.add(2);
      pq.add(1);
      pq.add(5);
      pq.add(23);
      
      System.out.println(pq);
      System.out.println(pq.poll());
      System.out.println(pq);
      System.out.println(pq.peek());
    }
}


output:

[1, 2, 10, 30, 5, 23]
1
[2, 5, 10, 30, 23]
2
