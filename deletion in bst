import java.util.*;

class Node{
    int data;
    Node left;
    Node right;

    Node(int data){
        this.data=data;
        this.left=null;
        this.right=null;
    }
}
public class bst_deletion{

    Node root=null;
    Node create(Node root,int val){

    if(root==null) return new Node(val);

    if(root.data>val){
        root.left=create(root.left,val);
    }
    else if(root.data<val){
        root.right=create(root.right,val);

    }
    return root;

}

Node delete(Node root,int val){
    if(root.data > val){
        root.left=delete(root.left,val);
    }
    else if(root.data < val){
        root.right=delete(root.right,val);

    }
    else{
        //leaf
        if(root.left==null && root.right==null){
            return null;
        }
        //single child left
        else if(root.left!=null && root.right==null){
            return root.left;
        }
        //single child right
        else if(root.right!=null && root.left==null){
            return root.right;
        }
        //two child
        else{
            root.data=minElement(root.right);
            root.right=delete(root.right,root.data);
        }
    }
    return root;
}

int minElement(Node root){
    int min=root.data;
    while(root.left!=null){
        root=root.left;
        min=root.data;
    }
    return min;
}

void inorder(Node root){
    if(root!=null){
      inorder(root.left);
      System.out.print(root.data+" ");
      inorder(root.right);
    }
}


    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        bst_deletion tree=new bst_deletion();
        int n,num;
        n=sc.nextInt();
        for(int i=0;i<n;i++){
            num=sc.nextInt();

            tree.root=tree.create(tree.root,num);
        }
        tree.inorder(tree.root);
        System.out.println();
        int val=sc.nextInt();
        tree.root=tree.delete(tree.root,val);
        tree.inorder(tree.root);

        

    }
}
